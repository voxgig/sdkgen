
main: kit: feature: retry: {

  name: key()
  title: "Automatic retry of transient failures with exponential backoff"
  version: '0.0.1'
  active: true

  config: {
    # Opt-in: enable per SDK via options.feature.retry.active = true
    options: {
      active: false
      retries: 2
      minDelay: 50
      maxDelay: 2000
      factor: 2
      statuses: [408, 425, 429, 500, 502, 503, 504]
    }
  }

  # Retry wraps the transport in init(); it dispatches no pipeline hooks.
  hook: {}
}
