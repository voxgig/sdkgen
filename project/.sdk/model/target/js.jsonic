
main: kit: target: js: {
  
  title: JavaScript
  ext: js
  comment: line: "//"
  module: name: $$name$$

  deps: &: {
    # TODO: fix aontu disjunctions!
    kind: *'prod' | string # 'peer' |'dev'
  }
  
  deps: {
    'dotenv': { active: true, version: '^17.4.2', kind: dev }
  }
}


main: kit: feature: &: target: js: deps: &: {
  # TODO: fix aontu disjunctions!
  kind: *'prod' | string # 'peer' |'dev'
}
